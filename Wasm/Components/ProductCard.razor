@using Infrastructure

<li class="@Product.Retailer">
  <img src="@Product.ImgUrl"/>
  <div>
    <a href="@Product.ItemUrl" target="_blank"><h3>@Product.Retailer</h3></a> 
    <p>@Product.Name</p>
    <p>R @Product.Price</p>
  </div>
</li>

@code {
  [Parameter] public required Product Product { get; set; }
}