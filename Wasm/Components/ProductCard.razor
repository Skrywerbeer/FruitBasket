@using Infrastructure

<li class="@Product.Retailer" 
    @onclick="ClickHandler"
    @onclick:stopPropagation="true"
    >
  <svg>
    
  </svg>
  <img src="@Product.ImgUrl"/>
  <div>
    <a href="@Product.ItemUrl" target="_blank">
      <h3>@Product.Retailer</h3></a>
    <p>@Product.Name</p>
    <p>R @Product.Price</p>
  </div>
</li>

@code {
  [Parameter] public required Product Product { get; set; }
  [Parameter] public EventCallback<Product> OnClick { get; set; }

  private async Task ClickHandler()
  {
    await OnClick.InvokeAsync(Product);
  }
}